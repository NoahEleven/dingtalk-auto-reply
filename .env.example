# ============================================================
# 钉钉自动回复 · 配置样例
# 用法：复制本文件为同目录 .env，按需修改后启动脚本
#       cp .env.example .env
# 说明：所有项均可选。留空 = 自动探测 / 使用默认值。
#       已存在的系统环境变量不会被本文件覆盖。
# ============================================================

# ---------- CodeBuddy 认证（二选一，推荐方式二做无人值守） ----------
# 方式一（推荐无人值守）：填 API Key，脚本用 Key 认证，不依赖交互登录
# 申请：https://copilot.tencent.com 控制台 → API Key
# CODEBUDDY_API_KEY=

# 方式二（零配置）：留空，复用你已在终端 `codebuddy` 登录过的凭据
# 未登录时脚本启动会打印提示，让你去终端登录。

# 网络环境：auto 检测（中国版 copilot.tencent.com 会自动识别）。
# 需要时强制覆盖：internal=中国版 / public=国际版
# CODEBUDDY_INTERNET_ENVIRONMENT=internal

# ---------- 外部二进制路径（一般无需改，自动探测 ~/.workbuddy 下） ----------
# CodeBuddy CLI（codebuddy.cmd）。留空=自动 glob 受管 node 目录。
# CODEBUDDY_CMD=
# Node 运行时（调 dws/微信推送用）。留空=自动探测。
# NODE=
# dws CLI 路径。留空=自动探测。
# DWS_CMD=
# 微信主动推送 send.js。留空=自动探测 weixinclaw-proactive-push skill。
# WEIXIN_SEND_JS=

# ---------- 行为参数 ----------
# 轮询间隔（秒）
# POLL_INTERVAL=10
# 抢答防护：发现未读后等待多久才代发（秒），给老板自己回的时间
# REPLY_DELAY_SEC=120
# 抢答防护：判定"老板正在跟"的活跃窗口（秒），窗口内老板发过消息则取消代发
# ACTIVE_WINDOW_SEC=300
# 不自动回复的名单（逗号分隔昵称/关键字），命中只通知不代发
# SKIP_SENDERS=
# 老板本人标识（逗号分隔），用于"避免回复自己"的兜底昵称匹配
# 隐私：填你自己的钉钉昵称/英文名，别留真实名在分发模板里。源码默认仅含中性词"老板"。
# SELF_SENDERS=你的昵称,你的英文名
# 群聊 @我 检测：老板的群昵称候选（逗号分隔），群消息 "@昵称" 前缀命中即判"有人@你"
# MENTION_NAMES=你的群昵称
# 通讯录搜索用的钉钉显示名（探测本人 openDingTalkId 的兜底；留空则跳过搜索）
# BOSS_DISPLAY_NAME=你的钉钉显示名
# 更精确：直接指定本人 openDingTalkId（配了这个就不需要 BOSS_DISPLAY_NAME）
# SELF_OPENDINGTALK_ID=
# 群聊微信推送策略（仅影响群消息是否推微信；单聊代复+提醒不受影响）：
#   atme = 仅 @我 / @all 才推（默认，最清净，过滤群刷屏/特别关注发言）
#   all  = 所有群消息都推（旧行为）
#   off  = 群聊完全不推微信（连@我都不推）
# GROUP_PUSH=atme

# ---------- 图片识别（多模态） ----------
# 默认：复用 hy3 内置多模态（CodeBuddy Agent SDK 的 image 协议），零额外配置、图片不出域。
#   —— 只要 codebuddy SDK 可用即自动启用，无需任何 key。
# 可选覆盖：若填了 VISION_API_KEY，则改用外部 OpenAI 兼容视觉 API（更快/更便宜的专用视觉模型，
#   如 gpt-4o-mini / 通义千问VL / 智谱GLM-4V / 本地ollama）。不填则走 hy3，无需配置。
# VISION_API_KEY=sk-xxxx
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini
# 单聊图片是否 AI 自动代复（基于"文字说明+图片描述"生成回复）。
# 默认开：图片消息也自动代复（老板要求「图片也默认代复」）。
# 设为 0 关闭（降级为仅识别+微信通知，不代发，防社死）：AUTO_REPLY_IMAGE=0
# 调试日志 / 审计日志 / 状态文件位置（默认 ~/.workbuddy 下）
# DEBUG_LOG=~/.workbuddy/dingtalk_auto_debug.log
# AUDIT_LOG=~/.workbuddy/dingtalk_auto_audit.jsonl
# STATE_FILE=~/.workbuddy/dingtalk_auto_state.json
